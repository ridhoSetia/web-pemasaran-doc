# DOC Mart Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================================================
# DJANGO CORE
# ============================================================================
DEBUG=False
SECRET_KEY=your-django-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ============================================================================
# DATABASE
# ============================================================================
DB_ENGINE=django.db.backends.mysql
DB_NAME=doc_mart_db
DB_USER=doc_mart_user
DB_PASSWORD=your-secure-database-password
DB_HOST=localhost
DB_PORT=3306

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
ENVIRONMENT=production
# Set to development for non-production environments

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# WhatsApp Integration (Fonnte API)
TOKEN_FONNTE=your-fonnte-api-token

# ============================================================================
# CELERY & REDIS (Advanced Features)
# ============================================================================

# Redis Configuration (for Celery broker and caching)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_URL=redis://redis:6379/1

# For local development without Redis:
# CELERY_BROKER_URL=memory://
# CELERY_RESULT_BACKEND=cache+memory://

# ============================================================================
# ERROR TRACKING (Sentry)
# ============================================================================

# Sentry DSN for error monitoring in production
# Leave blank to disable Sentry
# Get DSN from: https://sentry.io (create account → create project)
SENTRY_DSN=

# Example:
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ============================================================================
# LOGGING (Optional)
# ============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
